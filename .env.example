# --- Target APIs (sample: Gmail + Google Calendar) ---
# See PREPARATION.md for how to obtain a Google OAuth access token.
GOOGLE_ACCESS_TOKEN=

# Optional per-app override (same Google account is fine)
# GMAIL_ACCESS_TOKEN=
# GOOGLECALENDAR_ACCESS_TOKEN=

# Auth mode for connect.ts helpers: bearer (default) | api_key_header | api_key_query | basic | none
# AUTH_MODE=bearer

# API key in header (when AUTH_MODE=api_key_header)
# API_KEY_HEADER=X-API-Key
# API_KEY=

# API key in query string (when AUTH_MODE=api_key_query)
# API_KEY_PARAM=apikey

# Basic auth (when AUTH_MODE=basic)
# API_USER=
# API_PASS=

# --- LLM (I am using this one(easier for me to source it in my code editor))

# Anthropic Messages API (recommended for src_test/)
LLM_API_URL=https://api.anthropic.com/v1/messages
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514

# Concurrency (src_test/ — semaphore limits parallel use of same API keys)
HTTP_CONCURRENCY=4
LLM_CONCURRENCY=2

# OpenAI-compatible (OpenAI, Groq, Together, many gateways)
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini

# Ollama (local — no key usually needed)
# LLM_API_URL=http://localhost:11434/api/chat
# LLM_API_KEY=
# LLM_MODEL=llama3.2

# Hugging Face Inference (free tier — token at hf.co/settings/tokens)
# LLM_API_URL=https://api-inference.huggingface.co/models/meta-llama/Llama-3.2-3B-Instruct
# LLM_API_KEY=hf_xxxx
# LLM_MODEL=meta-llama/Llama-3.2-3B-Instruct

# Groq (free tier — console.groq.com)
# LLM_API_URL=https://api.groq.com/openai/v1/chat/completions
# LLM_API_KEY=
# LLM_MODEL=llama-3.3-70b-versatile
